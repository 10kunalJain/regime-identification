# URL of the FastAPI backend. When unreachable the dashboard falls back to
# the baked-in JSON at /regime_path.json + /regime_latest.json.
NEXT_PUBLIC_API_URL=https://api.example.com

# Vercel KV connection (auto-injected when the KV add-on is enabled for the
# project; needed for the ISR-cached blob fallback).
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
